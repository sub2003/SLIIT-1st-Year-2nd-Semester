   "source": [
    "def sum_recursive(n):\n",
    "    if n<= 0:\n",
    "        return 0\n",
    "    else:\n",
    "        return sum_recursive(n - 1) + n\n",
    "\n",
    "\n",
    "# Example\n",
    "n = 5\n",
    "print(\"Sum =\", sum_recursive(n))\n",
    "n=-1\n",
    "print(\"Sum =\", sum_recursive(n))"
   ]
